# ============================================================
# Telegram News Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# --- Required ---

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# --- Privacy (strongly recommended for personal bots) ---

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Find your ID by messaging @userinfobot on Telegram.
# Leave empty to allow everyone (not safe for public bots).
ALLOWED_USER_IDS=123456789


# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Voice (optional) ---

# Get from https://platform.openai.com — needed for voice transcription (Whisper)
# and voice replies (gTTS). If unset, voice messages are rejected with a hint.
OPENAI_API_KEY=your_openai_api_key_here

# --- Optional (defaults shown) ---

# SQLite (local/Docker): sqlite:///news_agent.db
# PostgreSQL (Railway addon): postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///news_agent.db

# Default daily digest delivery time (HH:MM, 24-hour UTC)
DEFAULT_DELIVERY_TIME=08:00

# Default timezone for new users
DEFAULT_TIMEZONE=UTC

# Path to the agents directory (relative to project root)
AGENTS_DIR=0. Agents

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=logs/bot.log
