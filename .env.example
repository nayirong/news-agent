# ============================================================
# Atlas + Donna Agents — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# --- Required (Atlas — news agent) ---

# Get from @BotFather on Telegram (first bot: Atlas)
TELEGRAM_BOT_TOKEN=your_atlas_bot_token_here

# --- Required (Donna — calendar secretary) ---

# Get from @BotFather on Telegram (second bot: Donna/Secretary)
TELEGRAM_BOT_TOKEN_SECRETARY=your_donna_bot_token_here

# Google Calendar service account JSON (full JSON string from downloaded key file)
# Setup: https://console.cloud.google.com → IAM → Service Accounts → Create → Download JSON
# Then share your Google Calendar with the service account email address.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Your Google Calendar ID (usually your Gmail address, or "primary")
GOOGLE_CALENDAR_ID=yourname@gmail.com

# IANA timezone for event creation (e.g. "Asia/Singapore", "America/New_York", "UTC")
GOOGLE_CALENDAR_TIMEZONE=UTC

# --- Privacy (strongly recommended for personal bots) ---

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Find your ID by messaging @userinfobot on Telegram.
# Leave empty to allow everyone (not safe for public bots).
ALLOWED_USER_IDS=123456789


# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Voice (optional) ---

# Get from https://platform.openai.com — needed for voice transcription (Whisper)
# and voice replies (gTTS). If unset, voice messages are rejected with a hint.
OPENAI_API_KEY=your_openai_api_key_here

# --- Optional (defaults shown) ---

# SQLite (local/Docker): sqlite:///news_agent.db
# PostgreSQL (Railway addon): postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///news_agent.db

# Default daily digest delivery time (HH:MM, 24-hour UTC)
DEFAULT_DELIVERY_TIME=08:00

# Default timezone for new users
DEFAULT_TIMEZONE=UTC

# Path to the agents directory (relative to project root)
AGENTS_DIR=0. Agents

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=logs/bot.log
